+    q' = BQ.mapMaybe f ts
 
 -- | \(O(n)\). Map elements and separate the 'Left' and 'Right' results.
 mapEither :: (Ord b, Ord c) => (a -> Either b c) -> MinQueue a -> (MinQueue b, MinQueue c)
-mapEither f q = (fromAscList ls, fromAscList rs)
-  where
-    (ls, rs) = partE (toListU q)
-    partE [] = ([], [])
-    partE (x:xs) = case f x of
-      Left  y -> case partE xs of (l, r) -> (y:l, r)
-      Right z -> case partE xs of (l, r) -> (l, z:r)
+mapEither _ Empty = (Empty, Empty)
+mapEither f (MinQueue _ x ts)
+  | (l, r) <- BQ.mapEither f ts
+  = case f x of
+      Left y ->
+        let !l' = fromBare (BQ.insertEager y l)
+            !r' = fromBare r
+        in (l', r')
+      Right z ->
+        let !l' = fromBare l
+            !r' = fromBare (BQ.insertEager z r)
+        in (l', r')
 
